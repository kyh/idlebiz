{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.ts",
        "src/renderer/main.tsx",
        "scripts/*.cjs"
      ],
      "project": [
        "src/**",
        "scripts/**"
      ],
      "ignoreDependencies": [
        "@mariozechner/pi-ai",
        "@mariozechner/pi-coding-agent",
        "@tailwindcss/vite",
        "@vitejs/plugin-react",
        "electron-builder"
      ],
      "ignoreBinaries": [
        "gh"
      ]
    }
  }
}
