{
  "name": "@repo/desktop",
  "version": "0.0.3",
  "private": true,
  "description": "IdleBiz desktop app",
  "author": "kyh",
  "type": "module",
  "main": "./.output/app/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --remoteDebuggingPort 9222",
    "build": "electron-vite build",
    "generate:office-objects": "node scripts/generate-office-object-catalog.cjs",
    "check:office": "node scripts/check-office-void.cjs",
    "start": "electron-vite preview",
    "release": "pnpm with-env electron-vite build && pnpm with-env electron-builder --mac --publish never",
    "release:publish": "GH_TOKEN=$(gh auth token) pnpm with-env electron-vite build && GH_TOKEN=$(gh auth token) pnpm with-env electron-builder --mac --publish always",
    "with-env": "dotenv -e .env --",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .cache .output"
  },
  "dependencies": {
    "@repo/agent-driver": "workspace:*",
    "phaser": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
