# Apple notarization, read by `pnpm -F @repo/desktop release` via dotenv (with-env).
# Only needed to sign + publish a build; `pnpm dev:desktop` and `pnpm build` do not
# use them. APPLE_API_KEY is the path to the App Store Connect .p8 key — keep the
# key file itself out of the repo (.gitignore covers *.p8).
APPLE_API_KEY=
APPLE_API_KEY_ID=
APPLE_API_ISSUER=
